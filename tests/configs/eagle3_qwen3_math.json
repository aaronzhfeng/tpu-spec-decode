{
  "name": "eagle3_qwen3_math",
  "model": "Qwen/Qwen3-4B",
  "draft_model": "AngelSlim/Qwen3-4B_eagle3",
  "prompt_source": "external",
  "use_chat_template": true,
  "datasets": ["gsm8k", "math500", "aime24", "aime25"],
  "max_samples": 8,
  "methods": ["baseline", "eagle3"],
  "sampling": {
    "temperature": 0.0,
    "top_p": 1.0,
    "top_k": 1,
    "max_tokens": 256,
    "ignore_eos": true
  },
  "runtime": {
    "tensor_parallel_size": 1,
    "max_model_len": 2048,
    "max_num_seqs": 1,
    "num_speculative_tokens": 3,
    "draft_tensor_parallel_size": 1,
    "warmup_prompts": 2,
    "inter_method_sleep_sec": 3.0,
    "async_scheduling": 0,
    "disable_log_stats": false,
    "seed": 0
  }
}
